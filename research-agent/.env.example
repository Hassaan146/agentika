# Copy to .env and fill in. Free keys: console.groq.com and serpapi.com
GROQ_API_KEY=
SERPAPI_API_KEY=

# Optional overrides (defaults in config.py). Everything tunable lives in
# config.py; these are the same knobs, exposed as env vars.

# Model & loop
# MODEL=llama-3.3-70b-versatile
# MAX_STEPS=8
# PLANNER_TEMPERATURE=0.2
# PLANNER_MAX_TOKENS=1024
# EXTRACTION_TEMPERATURE=0.0
# EXTRACTION_MAX_TOKENS=512

# Memory
# MEMORY_TOP_K=5
# HISTORY_MAX_MESSAGES=30
# HISTORY_HARD_CAP=200

# Tools / HTTP
# SEARCH_COUNT=5
# FETCH_MAX_CHARS=4000
# FILE_MAX_MB=5
# FILE_MAX_CHARS=8000
# HTTP_TIMEOUT=20
# HTTP_MAX_REDIRECTS=5
# RETRY_ATTEMPTS=3
# RETRY_BASE_DELAY=1.0

# Web server (session scoping + abuse controls)
# MAX_MESSAGE_CHARS=3000
# SESSION_TTL_SECONDS=1800
# SESSION_MAX=500
# RATE_LIMIT_PER_MIN=30

# Logging
# LOG_PREVIEW_CHARS=200
